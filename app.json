{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.audi",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Audi Connect"
  },
  "description": {
    "en": "Control and monitor your Audi vehicle from Homey"
  },
  "brandColor": "#000000",
  "category": [
    "appliances"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Thomas Thaulow Stöcklin",
    "email": "thaulow@thaulow.co"
  },
  "tags": {
    "en": [
      "audi",
      "car",
      "vehicle",
      "ev",
      "e-tron",
      "charging",
      "climate",
      "lock"
    ]
  },
  "api": {
    "refreshVehicle": {
      "method": "PUT",
      "path": "/vehicle/:vin/refresh"
    }
  },
  "flow": {
    "conditions": [
      {
        "title": {
          "en": "Fuel level is below..."
        },
        "titleFormatted": {
          "en": "Fuel level is below [[threshold]]%"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          },
          {
            "type": "range",
            "name": "threshold",
            "min": 0,
            "max": 100,
            "step": 5,
            "label": "%",
            "labelDecimals": 0
          }
        ],
        "id": "fuel_below"
      },
      {
        "title": {
          "en": "Vehicle is charging"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "is_charging"
      },
      {
        "title": {
          "en": "Climatisation is active"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "is_climatisation_active"
      },
      {
        "title": {
          "en": "A door is open"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "is_door_open"
      },
      {
        "title": {
          "en": "Vehicle is locked"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "is_locked"
      },
      {
        "title": {
          "en": "A window is open"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "is_window_open"
      },
      {
        "title": {
          "en": "Battery charge is below..."
        },
        "titleFormatted": {
          "en": "Battery charge is below [[threshold]]%"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          },
          {
            "type": "range",
            "name": "threshold",
            "min": 0,
            "max": 100,
            "step": 5,
            "label": "%",
            "labelDecimals": 0
          }
        ],
        "id": "soc_below"
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Lock the vehicle"
        },
        "hint": {
          "en": "Lock the vehicle doors (requires S-PIN)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "lock_vehicle"
      },
      {
        "title": {
          "en": "Refresh vehicle data"
        },
        "hint": {
          "en": "Ask the vehicle to push fresh data to the cloud. Data will be available after ~30 seconds."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "refresh_vehicle_data"
      },
      {
        "title": {
          "en": "Set target charge level"
        },
        "titleFormatted": {
          "en": "Set target charge level to [[target_soc]]%"
        },
        "hint": {
          "en": "Set the target state of charge for EV/PHEV vehicles (20-100% in steps of 5)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          },
          {
            "type": "range",
            "name": "target_soc",
            "min": 20,
            "max": 100,
            "step": 5,
            "label": "%",
            "labelDecimals": 0
          }
        ],
        "id": "set_target_soc"
      },
      {
        "title": {
          "en": "Start charging"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "start_charger"
      },
      {
        "title": {
          "en": "Start climatisation"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "start_climatisation"
      },
      {
        "title": {
          "en": "Start auxiliary heater"
        },
        "hint": {
          "en": "Start the auxiliary heater (requires S-PIN)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "start_preheater"
      },
      {
        "title": {
          "en": "Start window heating"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "start_window_heating"
      },
      {
        "title": {
          "en": "Stop charging"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "stop_charger"
      },
      {
        "title": {
          "en": "Stop climatisation"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "stop_climatisation"
      },
      {
        "title": {
          "en": "Stop auxiliary heater"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "stop_preheater"
      },
      {
        "title": {
          "en": "Stop window heating"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "stop_window_heating"
      },
      {
        "title": {
          "en": "Unlock the vehicle"
        },
        "hint": {
          "en": "Unlock the vehicle doors (requires S-PIN)"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=vehicle"
          }
        ],
        "id": "unlock_vehicle"
      }
    ]
  },
