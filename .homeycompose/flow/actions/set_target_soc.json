{
  "title": {
    "en": "Set target charge level"
  },
  "titleFormatted": {
    "en": "Set target charge level to [[target_soc]]%"
  },
  "hint": {
    "en": "Set the target state of charge for EV/PHEV vehicles (20-100% in steps of 5)"
  },
  "args": [
