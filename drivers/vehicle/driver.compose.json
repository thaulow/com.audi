{
  "name": {
    "en": "Audi Vehicle"
  },
  "class": "other",
  "capabilities": [
    "locked",
    "measure_temperature",
    "measure_mileage",
    "measure_fuel_level",
    "measure_range",
    "measure_oil_level",
    "measure_soc",
    "measure_charging_power",
    "charging_state",
    "target_soc",
    "alarm_doors_open",
    "alarm_windows_open",
    "alarm_trunk_open",
    "alarm_hood_open",
    "climatisation_active",
    "preheater_active",
    "window_heating_active",
    "measure_service_distance",
    "measure_service_time",
    "latitude",
    "longitude"
  ],
  "capabilitiesOptions": {
    "locked": {
      "title": {
        "en": "Door lock"
      }
    },
    "measure_temperature": {
      "title": {
        "en": "Outdoor temperature"
      }
    }
  },
  "energy": {},
  "platforms": [
    "local"
  ],
  "connectivity": [
    "cloud"
  ],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "pair": [
    {
      "id": "login",
      "template": "login_credentials",
      "options": {
        "title": "Audi Connect",
        "logo": "../assets/icon.svg",
        "usernameLabel": {
          "en": "myAudi email"
        },
        "passwordLabel": {
          "en": "myAudi password"
        }
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": {
        "en": "Account"
      },
      "children": [
        {
          "id": "username",
          "type": "text",
          "label": {
            "en": "myAudi email"
          },
          "value": ""
        },
        {
          "id": "password",
          "type": "password",
          "label": {
            "en": "myAudi password"
          },
          "value": ""
        },
        {
          "id": "spin",
          "type": "password",
          "label": {
            "en": "S-PIN (for lock/unlock)"
          },
          "value": ""
        },
        {
          "id": "region",
          "type": "dropdown",
          "label": {
            "en": "Region"
          },
          "value": "DE",
          "values": [
            { "id": "DE", "label": { "en": "Europe" } },
            { "id": "US", "label": { "en": "United States" } },
            { "id": "CA", "label": { "en": "Canada" } },
            { "id": "CN", "label": { "en": "China" } }
          ]
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "Polling"
      },
      "children": [
        {
          "id": "poll_interval",
          "type": "number",
          "label": {
            "en": "Update interval (minutes)"
          },
          "value": 15,
          "min": 5,
          "max": 120
        }
      ]
    },
    {
      "type": "group",
      "label": {
        "en": "Vehicle"
      },
      "children": [
        {
          "id": "vin",
          "type": "label",
          "label": {
            "en": "VIN"
          },
          "value": ""
        }
      ]
    }
  ]
}
